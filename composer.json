{
    "name": "ezscale/virtfusion-php",
    "description": "PHP SDK for the VirtFusion hosting API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "EZScale",
            "homepage": "https://ezscale.cloud"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "EZScale\\VirtFusion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EZScale\\VirtFusion\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
